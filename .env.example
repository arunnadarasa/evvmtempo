
# EVVM Testnet Contracts Environment Configuration
# Copy this file to .env and fill in your actual values

# =======================================================================================
# RPC ENDPOINTS
# =======================================================================================
# RPC URL for the target(s) host blockchain network
# You can get others in https://chainlist.org/


# Ethereum Sepolia Testnet RPC URL
# Primary: 0xRPC (reliable and fast)
#RPC_URL="https://0xrpc.io/sep"
# Alternatives (if primary fails):
# https://ethereum-sepolia.rpc.subquery.network/public (fastest: 0.165s)
# https://ethereum-sepolia.gateway.tatum.io
# https://sepolia.drpc.org
# https://gateway.tenderly.co/public/sepolia

# Arbitrum Sepolia Testnet RPC URL
# Primary: Official Arbitrum endpoint (most reliable)
#RPC_URL="https://sepolia-rollup.arbitrum.io/rpc"
# Alternatives (if primary fails):
# https://arbitrum-sepolia.gateway.tenderly.co (fastest: 0.167s)
# https://endpoints.omniatech.io/v1/arbitrum/sepolia/public
# https://arbitrum-sepolia.drpc.org
# https://api.zan.top/arb-sepolia

# Configuration for non cross-chain EVVM ================================================

# RPC URL for the chain you deploy to. For Tempo Moderato testnet (chain ID 42431):
# https://docs.tempo.xyz/quickstart/connection-details
RPC_URL="https://rpc.moderato.tempo.xyz"

# Local Anvil only — use when you run `anvil` and deploy to localhost (31337):
# RPC_URL="http://127.0.0.1:8545"

# Optional: deploy on a chain not yet whitelisted in the EVVM Registry (e.g. Tempo testnet)
# EVVM_SKIP_CHAIN_REGISTRY_CHECK=1
# EVVM_SKIP_EXPLORER_VERIFY=1
# EVVM_SKIP_REGISTRY_REGISTRATION=1

# Optional: override Foundry gas estimate multiplier — Foundry uses *percent* (600 = 6× estimate).
# Default on chain 42431 is 600: avoids -32003 "gas limit too high" on huge Core CREATEs while
# covering P2PSwap. If you see "intrinsic gas too low", try 650–700; if "gas limit too high", lower.
# EVVM_GAS_ESTIMATE_MULTIPLIER=600
# Optional: simulation block gas limit (default 30000000, matches Tempo's tx gas cap)
# EVVM_BLOCK_GAS_LIMIT=30000000
# Optional: set to 0 to disable --slow on Tempo (default on chain 42431: enabled)
# EVVM_BROADCAST_SLOW=1

# If Forge fails with "nonce too low" or "replacement transaction underpriced", stale
# broadcast state is likely. Remove the chain's artifacts and redeploy:
#   rm -rf broadcast/Deploy.s.sol/42431 cache/Deploy.s.sol/42431

# Optional: deploy only P2PSwap after Core + Staking already exist (e.g. partial Tempo deploy).
# Generate correct exports from your last Foundry broadcast (no placeholders):
#   chmod +x scripts/print-p2pswap-env.sh
#   eval "$(./scripts/print-p2pswap-env.sh)"
# (Printing the script output alone does not set variables — you must use eval.)
# Or copy addresses from broadcast/Deploy.s.sol/42431/run-latest.json (contractName Core / Staking).
# Each value must be a FULL literal address: only 0x plus hex digits (0-9 a-f), 42 characters total.
# Do not paste English placeholders like 0xYourRealCoreAddressHere42Chars.
# EVVM_P2PSWAP_CORE=0x0000000000000000000000000000000000000000
# EVVM_P2PSWAP_STAKING=0x0000000000000000000000000000000000000000
# EVVM_P2PSWAP_OWNER=0x0000000000000000000000000000000000000000
# (replace zeros with real addresses; owner matches admin in input/BaseInputs.sol)
#
# Paste-safe exports for zsh (one line per variable; do not add "or 1000" on the same line as export).
# EVVM_GAS_ESTIMATE_MULTIPLIER=700
# P2PSwap-only deploy is a single large CREATE; 700–800 is often used if 600 fails intrinsic checks.
#
# Example (Moderato 42431; use your --account name; load env from .env or export):
#   forge script script/DeployP2PSwapOnly.s.sol:DeployP2PSwapOnlyScript \
#     --via-ir --optimize true --rpc-url "$RPC_URL" --account defaultKey --broadcast -vvvv \
#     --gas-estimate-multiplier "${EVVM_GAS_ESTIMATE_MULTIPLIER:-700}" \
#     --block-gas-limit "${EVVM_BLOCK_GAS_LIMIT:-30000000}" --slow

# Configuration for cross-chain EVVM ====================================================

# RPC URL for external blockchain de deploy TreasuryExternalChainStation.sol
EXTERNAL_RPC_URL="https://sepolia-rollup.arbitrum.io/rpc"
# RPC URL for host blockchain to deploy TreasuryHostChainStation.sol and EVVM instance
HOST_RPC_URL="https://0xrpc.io/sep"

# Configuration for EVVM registration ===================================================

# RPC URL for optional registration on Ethereum Sepolia Testnet
EVVM_REGISTRATION_RPC_URL="https://gateway.tenderly.co/public/sepolia"

# =======================================================================================
# BLOCKCHAIN EXPLORERS API KEYS
# =======================================================================================
# Etherscan v2 API Key (for contract verification on Ethereum networks)
# Get from: https://etherscan.io/apis
ETHERSCAN_API="YOUR_ETHERSCAN_API_KEY"