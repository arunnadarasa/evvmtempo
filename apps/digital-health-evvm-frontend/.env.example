# Network target (see src/config/contracts.ts)
# - tempo-moderato — EVVM on Tempo Moderato (chain 42431); default if unset
# - base-sepolia — Digital Health demo + MPP sections below
VITE_TARGET_NETWORK=tempo-moderato

# MPP-style demos (Base Sepolia only in UI — set VITE_TARGET_NETWORK=base-sepolia)
# Reference: /Users/openclaw/Documents/Tempo (DanceTempo, mppx, docs/MPPSCAN_DISCOVERY.md)
VITE_MPP_SERVER_URL=http://localhost:8080
VITE_MPP_USDC_ECHO_URL=https://x402.payai.network/api/base-sepolia/paid-content

# Legacy names (still read if VITE_MPP_* unset):
